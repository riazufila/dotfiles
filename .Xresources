! special
! [number] before hex color code is the opacity level
URxvt*foreground:   [100]#a5a2a2
URxvt*background:   [75]#090300
URxvt*cursorColor:  #a5a2a2

! black
URxvt*color0:       #090300
URxvt*color8:       #5c5855

! red
URxvt*color1:       #db2d20
URxvt*color9:       #db2d20

! green
URxvt*color2:       #01a252
URxvt*color10:      #01a252

! yellow
URxvt*color3:       #fded02
URxvt*color11:      #fded02

! blue
URxvt*color4:       #01a0e4
URxvt*color12:      #01a0e4

! magenta
URxvt*color5:       #a16a94
URxvt*color13:      #a16a94

! cyan
URxvt*color6:       #b5e4f4
URxvt*color14:      #b5e4f4

! white
URxvt*color7:       #a5a2a2
URxvt*color15:      #f7f7f7

! Force a visual with alpha channel to create transparency
URxvt*depth: 32

! Font declaration
URxvt*font: xft:Inconsolata:size=11
URxvt*boldFont: xft:Inconsolata:bold:size=11
URxvt*italicFont: xft:Inconsolata:italic:size=11
URxvt*boldItalicfont: xft:Inconsolata:bold:italic:size=11

! Place scroll bar at the right
URxvt*scrollBar_right: true

! Disable default terminal contents printing when pressing PrintScreen
! Use gnome-screenshot to printscreen by editing i3 dotfile
URxvt.print-pipe: "cat > /dev/null"
