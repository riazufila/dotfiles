! special
! [number] before hex color code is the opacity level (Must be
! paired with URxvt.depth: 32)
!URxvt.foreground:   [100]#ffffff
!URxvt.background:   [75]#090300
!URxvt.cursorColor:  #a5a2a2

! black
!URxvt.color0:       #090300
!URxvt.color8:       #5c5855

! red
!URxvt.color1:       #db2d20
!URxvt.color9:       #db2d20

! green
!URxvt.color2:       #01a252
!URxvt.color10:      #01a252

! yellow
!URxvt.color3:       #fded02
!URxvt.color11:      #fded02

! blue
!URxvt.color4:       #01a0e4
!URxvt.color12:      #01a0e4

! magenta
!URxvt.color5:       #a16a94
!URxvt.color13:      #a16a94

! cyan
!URxvt.color6:       #b5e4f4
!URxvt.color14:      #b5e4f4

! white
!URxvt.color7:       #a5a2a2
!URxvt.color15:      #f7f7f7

! special
*.foreground:   [100]#ffffff
*.background:   [75]#000000
*.cursorColor:  #ffffff

! black
*.color0:       #101010
*.color8:       #404040

! red
*.color1:       #e84f4f
*.color9:       #d23d3d

! green
*.color2:       #b8d68c
*.color10:      #a0cf5d

! yellow
*.color3:       #e1aa5d
*.color11:      #f39d21

! blue
*.color4:       #7dc1cf
*.color12:      #4e9fb1

! magenta
*.color5:       #9b64fb
*.color13:      #8542ff

! cyan
*.color6:       #6d878d
*.color14:      #42717b

! white
*.color7:       #dddddd
*.color15:      #dddddd

! Force a visual with alpha channel to create transparency
URxvt.depth: 32

! DPI
URxvt.dpi: 96

! Type of subpixel antialiasing (none, rgb, bgr, vrgb or vbgr)
Xft.rgba: rgb
Xft.antialias: 1

! LCD filter
Xft.lcdfilter: lcddefault

! Hinting
Xft.hinting: 1
Xft.autohint: 0

! Degree of hinting to use (hintnone, hintslight, hintmedium, or hintfull)
Xft.hintstyle: hintfull

! Font declaration
URxvt.font: xft:Inconsolata:size=11
URxvt.boldFont: xft:Inconsolata:bold:size=11
URxvt.italicFont: xft:Inconsolata:italic:size=11
URxvt.boldItalicfont: xft:Inconsolata:bold:italic:size=11

! Place scroll bar at the right
URxvt.scrollBar: false

! Disable default terminal contents printing when pressing PrintScreen
! Use gnome-screenshot to printscreen by editing i3 dotfile
URxvt.print-pipe: "cat > /dev/null"

! Set internal border (border)
URxvt.internalBorder: 10
